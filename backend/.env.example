# Copy to backend/.env for local (non-Docker) runs. Docker Compose sets these itself.
DEBUG=1
SECRET_KEY=dev-only-secret-change-me
# Local Postgres (matches docker-compose). In production, set this to Neon's POOLED URL.
DATABASE_URL=postgres://mgs:mgs@localhost:5444/mgs
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5175
# Keep 0 on serverless (Vercel); a small positive value is fine for a long-lived container.
CONN_MAX_AGE=0

# --- Auth emails (djoser activation + password reset) ---
# Dev defaults to Django's console backend (emails print to the log) — no Brevo key
# needed. In production set EMAIL_BACKEND to Anymail's Brevo backend and provide the key.
# EMAIL_BACKEND=anymail.backends.brevo.EmailBackend
# BREVO_API_KEY=your-brevo-transactional-api-key
DEFAULT_FROM_EMAIL=no-reply@mgs-dev.local
# Where the SPA serves the /activate and /reset-password pages the emailed links point at.
FRONTEND_DOMAIN=mgs-dev.local
# FRONTEND_PROTOCOL=https
# SITE_NAME=Ma Garde Sereine
